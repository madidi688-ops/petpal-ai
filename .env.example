# ===== 后端（本地默认 SQLite）=====
DATABASE_URL="file:./dev.db"
# 若改用 Docker Postgres：
# DATABASE_URL=postgresql://petpal:petpal@localhost:5432/petpal?schema=public
REDIS_URL=redis://localhost:6379
PORT=4000
NODE_ENV=development

# ===== LLM =====
# DeepSeek 官方：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-please-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_VL_MODEL=deepseek-vl

# 鉴权共享密钥（前端 ↔ 后端）
NEXTAUTH_SECRET=please-generate-with-openssl-rand-base64-32

# ===== 前端 =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
