# ===== 后端（Docker 起 Postgres + Redis 后的本机开发配置）=====
DATABASE_URL=postgresql://petpal:petpal@localhost:5432/petpal?schema=public
# 若暂时不用 Docker、退回 SQLite：
# DATABASE_URL="file:./dev.db"
REDIS_URL=redis://localhost:6379
PORT=4001
NODE_ENV=development

# ===== LLM =====
# DeepSeek 官方：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-please-replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== 多模态（图/视频）→ 火山方舟 Responses API =====
# curl 示例：POST https://ark.cn-beijing.volces.com/api/v3/responses
ARK_API_KEY=ark-please-replace-me
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-1-pro-260628
# 远端要拉本机 uploads 时改成电脑局域网 IP
# PUBLIC_BASE_URL=http://localhost:4001

NEXTAUTH_SECRET=please-generate-with-openssl-rand-base64-32

# ===== 前端 =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001
NEXTAUTH_URL=http://localhost:3000
